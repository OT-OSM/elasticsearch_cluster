# ==============================================================================
# OpenSearch Dashboards Configuration
# ==============================================================================

server.port: {{ elasticsearch_dashboard_port }}
server.host: "{{ elasticsearch_dashboard_host }}"
server.name: "{{ elasticsearch_dashboard_server_name }}"

# --- Backend Connectivity ---
opensearch.hosts: ["{{ elasticsearch_api_protocol }}://localhost:{{ elasticsearch_http_port }}"]
opensearch.ssl.verificationMode: none

# --- Security & Authentication ---
{% if elasticsearch_dashboard_oidc_enabled | bool %}
opensearch_security.auth.type: "oidc"
opensearch_security.openid.connect_url: "{{ elasticsearch_dashboard_oidc_connect_url }}"
opensearch_security.openid.client_id: "{{ elasticsearch_oidc_realms[0].rp_client_id }}"
opensearch_security.openid.client_secret: "{{ elasticsearch_oidc_realms[0].rp_client_secret }}"
opensearch_security.openid.base_redirect_url: "{{ elasticsearch_dashboard_oidc_base_url }}"
opensearch_security.cookie.secure: true
opensearch_security.session.keepalive: true
{% else %}
opensearch_security.auth.type: "basicauth"
{% endif %}

# --- Premium Branding & UI ---
opensearch_dashboards.branding:
  logo:
    defaultUrl: "https://opstree.com/wp-content/uploads/2021/11/logo.png"
  mark:
    defaultUrl: "https://opstree.com/wp-content/uploads/2021/11/favicon.png"
  applicationTitle: "Opstree Data Insights"

# --- Advanced Features ---
opensearch_dashboards.index: ".opensearch_dashboards"
region: "{{ elasticsearch_minio_region }}"
